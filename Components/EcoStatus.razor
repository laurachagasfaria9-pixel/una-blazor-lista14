<div class="card p-3 m-2 shadow">
    <h4>@Titulo</h4>

    <p>Total: @Total</p>

    <button class="btn btn-success" @onclick="Incrementar">
        +@Peso
    </button>

    @if (Total >= 100)
    {
        <p class="text-success">🌱 Você é um Herói do Planeta!</p>
    }

    <div class="progress mt-2">
        <div class="progress-bar" role="progressbar"
             style="width:@Progresso%">
            @Progresso%
        </div>
    </div>
</div>

@code {
    [Parameter]
    public string Titulo { get; set; }

    [Parameter]
    public int Peso { get; set; }

    private int Total = 0;

    private void Incrementar()
    {
        Total += Peso;
    }

    private int Progresso => Total > 100 ? 100 : Total;
}